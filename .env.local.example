# Database (PostgreSQL on EC2)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE

# Google APIs
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...
GOOGLE_PLACES_API_KEY=AIzaSy...

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# ISR Revalidation
REVALIDATION_SECRET=your-secret-token

# Cloudflare cache purge (server-side only; use a token scoped to Zone:Cache Purge)
CLOUDFLARE_API_TOKEN=your-cache-purge-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_PURGE_HOSTS=www.zavis.ai

# Journal Automation — Gemini API (content generation + image generation)
GEMINI_API_KEY=AIzaSy...

# Journal Automation — Resend (for newsletter)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=aud_...

# Journal Automation — Cron security
CRON_SECRET=your-cron-secret

# Search Engine Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=your-yandex-verification-code

# ── Research Ecosystem ───────────────────────────────────────────
# Dashboard authentication
DASHBOARD_KEY=your-dashboard-key
REPORTS_API_KEY=your-reports-api-key

# Postiz (Social Media Scheduling — local Docker stack)
POSTIZ_API_BASE=http://localhost:4007/api
POSTIZ_JWT_SECRET=your-postiz-jwt-secret
POSTIZ_USER_ID=your-postiz-user-id

# Plunk (Email Marketing)
PLUNK_SECRET_KEY=sk_...

# ElevenLabs (AI Voiceover)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Google APIs (Analytics — for performance loop)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=your-base64-encoded-private-key
GA4_PROPERTY_ID=properties/123456789
GSC_SITE_URL=https://research.zavis.ai
