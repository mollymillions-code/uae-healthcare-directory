WEBHOOK_SECRET=replace-with-a-long-random-secret
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8787
WEBHOOK_PATH=/hooks/github/live-deploy
WEBHOOK_MAX_BODY_BYTES=10485760

DEPLOY_BRANCH=live
DEPLOY_REPO=zavis-support/zavis-landing
DEPLOY_SCRIPT=/home/ubuntu/zavis-deploy/deploy.sh
DEPLOY_TIMEOUT_MS=3600000
DEPLOY_WEBHOOK_LOG=/home/ubuntu/logs/webhook-deploy.log
DEPLOY_WEBHOOK_STATUS=/home/ubuntu/zavis-deploy/webhook-status.json

NEXT_PRIVATE_BUILD_WORKER_COUNT=1
