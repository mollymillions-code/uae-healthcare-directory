DB_NAME=zavis_landing
DB_BACKUP_DIR=/var/backups/zavis-landing
DB_BACKUP_LOCAL_RETENTION=14

# Optional encrypted off-box backup upload.
DB_BACKUP_REMOTE_ENABLED=0
DB_BACKUP_SOURCE_ENV=/home/ubuntu/zavis-shared/.env.local
DB_BACKUP_REMOTE_PREFIX=database-backups/zavis-landing
DB_BACKUP_REMOTE_RETENTION=30
DB_BACKUP_ENCRYPTION_KEY_FILE=/home/ubuntu/zavis-deploy/db-backup-encryption.key

# Optional alert hook. The scripts run without it and write logs/status files.
DB_BACKUP_ALERT_WEBHOOK_URL=
