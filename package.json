{
  "name": "uae-health-directory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx src/lib/db/seed.ts",
    "db:seed-journal": "npx tsx scripts/seed-journal-to-db.ts",
    "db:studio": "drizzle-kit studio",
    "scrape:mohap": "npx tsx src/lib/scrapers/mohap-scraper.ts",
    "scrape:mohap:test": "npx tsx src/lib/scrapers/mohap-scraper.ts 1 3",
    "scrape:dha": "npx tsx src/lib/scrapers/dha-scraper.ts",
    "journal:ingest": "npx tsx -e \"import { runContentPipeline } from './src/lib/journal/automation/pipeline'; runContentPipeline().then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "journal:newsletter": "npx tsx -e \"import { runNewsletterPipeline } from './src/lib/journal/automation/pipeline'; runNewsletterPipeline().then(r => console.log(JSON.stringify(r, null, 2)))\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^1.0.2",
    "@vis.gl/react-google-maps": "^1.7.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^3.3.11",
    "next": "14.2.35",
    "playwright": "^1.58.2",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.4",
    "rss-parser": "^3.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
