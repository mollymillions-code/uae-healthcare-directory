{
  "name": "zavis-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx src/lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "scrape:mohap": "npx tsx src/lib/scrapers/mohap-scraper.ts",
    "scrape:mohap:test": "npx tsx src/lib/scrapers/mohap-scraper.ts 1 3",
    "scrape:dha": "npx tsx src/lib/scrapers/dha-scraper.ts",
    "journal:ingest": "npx tsx -e \"import { runContentPipeline } from './src/lib/intelligence/automation/pipeline'; runContentPipeline().then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "journal:newsletter": "npx tsx -e \"import { runNewsletterPipeline } from './src/lib/intelligence/automation/pipeline'; runNewsletterPipeline().then(r => console.log(JSON.stringify(r, null, 2)))\"",
    "auto:migrate": "node scripts/automation/migrate.mjs",
    "auto:seed": "node scripts/automation/seed-schedules.mjs",
    "auto:install": "node scripts/automation/install-plists.mjs",
    "auto:start": "node scripts/automation/install-plists.mjs --load",
    "auto:stop": "node scripts/automation/uninstall-plists.mjs",
    "auto:status": "node scripts/automation/status.mjs",
    "cache:directory": "node scripts/revalidate-directory-cache.mjs",
    "auto:run-weekly": "node scripts/automation/orchestrator.mjs --mode weekly",
    "auto:run-daily": "node scripts/automation/orchestrator.mjs --mode daily --slot morning",
    "auto:run-review": "node scripts/automation/orchestrator.mjs --mode review",
    "auto:health": "node scripts/automation/orchestrator.mjs --mode health",
    "media:audit": "node scripts/audit-directory-media.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@plunk/node": "^3.0.3",
    "@vis.gl/react-google-maps": "^1.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^164.1.0",
    "gsap": "^3.14.2",
    "isomorphic-dompurify": "^3.7.1",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "nanoid": "^3.3.11",
    "next": "14.2.35",
    "next-themes": "^0.2.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "react-fast-marquee": "^1.6.5",
    "react-icons": "^5.6.0",
    "react-phone-input-2": "^2.15.1",
    "react-toastify": "^11.0.5",
    "resend": "^6.9.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "sharp-cli": "^5.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "html-encoding-sniffer": "4.0.0"
  }
}
